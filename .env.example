# Kopiere diese Datei nach .env und fülle die Werte aus
# .env wird NICHT ins Git eingecheckt

# PostgreSQL
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_PASSWORD=changeme_redis_password

# JWT Signing Key (openssl rand -hex 32)
SECRET_KEY=changeme_jwt_secret_key_min_32_chars

# Fernet Encryption Key für Connector-Credentials
# Generieren: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_fernet_key

# OpenSearch Feed-Storage (min. 8 Zeichen, 1 Großbuchstabe, 1 Zahl)
OPENSEARCH_PASSWORD=changeme_OpenSearch1

# AWX (nur wenn docker-compose.awx.yml verwendet wird)
# docker compose -f docker-compose.yml -f docker-compose.awx.yml up -d
AWX_DB_PASSWORD=changeme_awxdb
AWX_ADMIN_PASSWORD=changeme_awxadmin
AWX_SECRET_KEY=changeme_awxsecretkey_min32chars_xyz
