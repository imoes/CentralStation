# Per-user code-server (VS Code in the browser) image for the Werkbank.
# Provides the Web-IDE, the integrated multi-tab terminal (copy/paste), and
# native Git. One container is started per user by the backend (app/api/ide.py).
#
# Build:  docker compose build codeserver   (tags centralstation-codeserver:latest)
FROM codercom/code-server:latest

USER root

ARG HTTP_PROXY=""
ARG HTTPS_PROXY=""
ARG NO_PROXY="localhost,127.0.0.1"

ENV http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY}

# git + ssh client + Python for Ansible
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git openssh-client ca-certificates curl jq \
        python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Ansible + ansible-lint for local syntax checks and quick tests without AWX.
# ansible-playbook -i "localhost," -c local playbook.yml runs entirely in the container.
RUN pip3 install --break-system-packages ansible ansible-lint 2>/dev/null \
    || pip3 install ansible ansible-lint

# Claude Code CLI — usable from the integrated terminal. Native installer
# (the image ships no node/npm). Installs to /root/.local/bin (build user=root,
# runtime user=root). PATH set below so `claude` resolves.
ENV PATH=/root/.local/bin:$PATH
RUN curl -fsSL https://claude.ai/install.sh | bash \
    && (ln -sf /root/.local/bin/claude /usr/local/bin/claude 2>/dev/null || true) \
    && claude --version
# Persist Claude Code credentials on the per-user config volume (mounted at runtime).
ENV CLAUDE_CONFIG_DIR=/root/.claude

# Pre-install the AI coding-agent VS Code extensions (from Open VSX, code-server's
# default registry): Claude Code + OpenAI Codex. They are installed into a staging
# dir baked into the image — NOT /root/.local/share/code-server, which is a per-user
# bind mount at runtime and would mask anything installed there at build time. The
# entrypoint seeds these into each user's extensions dir on first start.
RUN code-server \
        --extensions-dir /opt/cs-extensions \
        --install-extension Anthropic.claude-code \
        --install-extension openai.chatgpt \
    && ls -1 /opt/cs-extensions

RUN touch /root/.bashrc

COPY entrypoint.codeserver.sh /usr/local/bin/cs-entrypoint.sh
RUN chmod +x /usr/local/bin/cs-entrypoint.sh

USER coder
ENTRYPOINT ["/usr/local/bin/cs-entrypoint.sh"]
